<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Frosty's Advertisement Services</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; background-image: url('https://www.transparenttextures.com/patterns/dark-matter.png'); }
        .glass-card { background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(12px); border: 1px solid rgba(56, 189, 248, 0.2); transition: all 0.3s ease; }
        .glass-card:hover { transform: translateY(-5px); border-color: rgba(56, 189, 248, 0.5); }
        .product-img { width: 80px; height: 80px; margin: 0 auto 1.5rem; filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.4)); }
    </style>
</head>
<body class="text-slate-200 font-sans pb-20">
    <header class="py-16 text-center">
        <h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-300 to-blue-500 mb-4">FROSTY'S</h1>
        <p class="text-cyan-400 tracking-[0.4em] uppercase text-sm font-bold opacity-80">Advertisement Services</p>
    </header>

    <main class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-10 flex items-center gap-4"><span class="h-1 w-12 bg-cyan-500 rounded-full"></span> Paketler</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-20">
            <!-- Ice Cube Pack -->
            <div class="glass-card p-8 rounded-[2rem] text-center flex flex-col justify-between border-t-4 border-t-cyan-400">
                <div>
                    <img src="https://img.icons8.com/isometric/100/3498db/ice-cube.png" class="product-img">
                    <h3 class="text-xl font-bold text-white mb-1">Ice Cube Pack</h3>
                    <p class="text-3xl font-black text-cyan-400 mb-4">£13.00</p>
                    <p class="text-xs text-slate-400 mb-6">1 Ay Reklam, haftada 3 gönderim, özel kanal ve tüm pingler.</p>
                </div>
                <a href="https://buy.stripe.com/3cI4gBakQ3OmcIr4U4bwk08" class="block w-full py-4 bg-cyan-500 hover:bg-cyan-400 text-slate-900 font-black rounded-2xl transition">SATIN AL</a>
            </div>
            <!-- Frost Pack -->
            <div class="glass-card p-8 rounded-[2rem] text-center flex flex-col justify-between border-t-4 border-t-blue-500">
                <div>
                    <img src="https://img.icons8.com/isometric/100/3498db/frozen-window.png" class="product-img">
                    <h3 class="text-xl font-bold text-white mb-1">Frost Pack</h3>
                    <p class="text-3xl font-black text-blue-400 mb-4">£10.00</p>
                    <p class="text-xs text-slate-400 mb-6">3 Hafta Reklam, özel kanal ve Everyone pingi.</p>
                </div>
                <a href="https://buy.stripe.com/28E00lakQfx44bVaeobwk09" class="block w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-2xl transition">SATIN AL</a>
            </div>
            <!-- Tier Pack -->
            <div class="glass-card p-8 rounded-[2rem] text-center flex flex-col justify-between">
                <div>
                    <img src="https://img.icons8.com/isometric/100/3498db/layers.png" class="product-img">
                    <h3 class="text-xl font-bold text-white mb-1">Tier Pack</h3>
                    <p class="text-3xl font-black text-slate-100 mb-4">£7.00</p>
                    <p class="text-xs text-slate-400 mb-6">1 Hafta Reklam, haftada 1 gönderim ve Everyone pingi.</p>
                </div>
                <a href="https://buy.stripe.com/eVq28t64AdoW4bVgCMbwk0a" class="block w-full py-4 bg-slate-700 hover:bg-slate-600 text-white font-black rounded-2xl transition">SATIN AL</a>
            </div>
            <!-- Melting Pack -->
            <div class="glass-card p-8 rounded-[2rem] text-center flex flex-col justify-between">
                <div>
                    <img src="https://img.icons8.com/isometric/100/3498db/water.png" class="product-img">
                    <h3 class="text-xl font-bold text-white mb-1">Melting Pack</h3>
                    <p class="text-3xl font-black text-slate-100 mb-4">£3.00</p>
                    <p class="text-xs text-slate-400 mb-6">5 Gün Reklam, tek seferlik gönderim ve Here pingi.</p>
                </div>
                <a href="https://buy.stripe.com/fZuaEZakQdoW7o7cmwbwk0b" class="block w-full py-4 bg-slate-700 hover:bg-slate-600 text-white font-black rounded-2xl transition">SATIN AL</a>
            </div>
        </div>

        <!-- Ekstralar -->
        <h2 class="text-2xl font-bold mb-8 flex items-center gap-4"><span class="h-1 w-8 bg-blue-500 rounded-full"></span> Özelleştirmeler</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="glass-card p-6 rounded-[1.5rem] flex items-center justify-between border border-yellow-500/30">
                <div class="flex items-center gap-4">
                    <img src="https://img.icons8.com/isometric/50/f1c40f/heart.png" class="w-12 h-12">
                    <div>
                        <h4 class="font-bold text-yellow-400">Bağış (Donation)</h4>
                        <p class="text-slate-400 text-xs">£1.00 - £99.00 Arası</p>
                    </div>
                </div>
                <a href="https://buy.stripe.com/eVqaEZ2Soet06k386gbwk06" class="px-6 py-2 bg-yellow-500 hover:bg-yellow-400 text-slate-900 rounded-lg font-bold transition">Destek Ol</a>
            </div>
            <div class="glass-card p-6 rounded-[1.5rem] flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <img src="https://img.icons8.com/isometric/50/3498db/megaphone.png" class="w-12 h-12">
                    <div>
                        <h4 class="font-bold text-white">Custom Ad</h4>
                        <p class="text-cyan-400 font-bold">£3.00</p>
                    </div>
                </div>
                <a href="https://buy.stripe.com/6oUaEZ2SockScIrgCMbwk07" class="px-6 py-2 bg-blue-600 hover:bg-blue-500 rounded-lg font-bold transition">Ekle</a>
            </div>
        </div>

        <div class="mt-12 p-8 glass-card rounded-[2rem] text-center">
            <p class="text-sm text-slate-400">🔔 Satın aldıktan sonra Discord'da ticket açıp Frostyy_101'i pingleyin!</p>
        </div>
    </main>
</body>
</html>
